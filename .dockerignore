# See https://docs.docker.com/engine/reference/builder/#dockerignore-file for more about ignoring files.

# Ignore git and version control
/.git/
/.github/
/.gitattributes
/.gitignore

# Ignore bundler config but ensure we can still copy Gemfile
/.bundle
/vendor/bundle
/vendor/cache

# Ignore environment files (except templates)
/.env*
!/.env*.erb
!/.env.example

# Ignore all default key files (but allow mounting in K8s)
/config/master.key
/config/credentials/*.key

# Ignore all development logfiles and tempfiles
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep d
!/tmp/pids
!/tmp/pids/.keep d
!/tmp/k8s
!/tmp/k8s/.keep

# Ignore storage (uploaded files in development, will be mounted in K8s)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore development-specific files
/.byebug_history
.DS_Store
*.swp
*.swo
/.idea/
/.vscode/

# Ignore assets that will be precompiled during build
/node_modules/
/app/assets/builds/*
!/app/assets/builds/.keep

# DO NOT ignore these in production builds
!/public/assets/
!/public/packs/
!/public/packs-test/

# Ignore documentation
/README.md
/CHANGELOG.md
/LICENSE.md
/doc/
/docs/

# Ignore test files
/test/
/spec/
/features/
/coverage/
.rspec

# Ignore Docker and CI files (so changes don't trigger rebuilds)
/Dockerfile*
!Dockerfile.production
/.dockerignore
/docker-compose*.yml
/.travis.yml
/.circleci/
/k8s/
